# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/mcp/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# API keys (SOP có thể dùng file này — không commit)
resend_config.txt
resend_config.txt.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Production SQLite data (Docker bind mount /opt/pickleball-landing/data on VPS,
# /data/brain-mcp-test.db trong dev). Tránh git stash -u xóa brain.db khi pull code.
/data/
!/data/.gitkeep

# AI image API artifacts (response chứa URL hết hạn, body tạm)
dall-e-response*.json
gpt-image-*-resp.json
body.json
probe*.json
COMMIT_MSG.tmp

# goClaw session backup khi reset (chứa lịch sử chat private)
session_backup*.json
