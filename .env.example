# Sao chép thành .env.local và điền giá trị. Trên Vercel: Settings → Environment Variables (Production).

# --- Database (production: Postgres; local có thể để trống để dùng SQLite) ---
# POSTGRES_URL=
# DATABASE_URL=
# STORAGE_URL=

# --- Resend (email waitlist, sequence, xác nhận đơn) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Cron /api/cron/email-sequence (tuỳ chọn; Vercel tự gửi Bearer khi có biến này) ---
# CRON_SECRET=

# --- SePay ---
# SEPAY_MERCHANT_ID=
# SEPAY_SECRET_KEY=
# SEPAY_WEBHOOK_API_KEY=
# SEPAY_PRODUCT_ID=
# CAM_NANG_PRODUCT_ID=          # ID sản phẩm 68k trong /admin (Day 19 PDF)
# NEXT_PUBLIC_SITE_URL=https://pickleball30phut.com

# --- Lead form → Make (tuỳ chọn) ---
# NEXT_PUBLIC_MAKE_WEBHOOK_URL=

# --- VPS / goClaw DB (chỉ cho scripts/ chạy local; KHÔNG commit .env thật) ---
# VPS_HOST=103.97.127.221
# VPS_PORT=2018
# VPS_USER=root
# VPS_PASS=                        # bắt buộc — đặt qua .env hoặc shell, không hardcode
# GOCLAW_AGENT_KEY=coach-ppr
# GOCLAW_DB_CONTAINER=goclaw-pickleball-postgres-1
# GOCLAW_USER_ID=8616188982        # Telegram user id (cho scripts read_memory.py / reset_session.py)
# GOCLAW_SESSION_ID=               # uuid cho reset_session.py (optional, có thể truyền argv)
