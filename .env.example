# Sao chép thành .env.local và điền giá trị. Trên Vercel: Settings → Environment Variables (Production).

# --- Database (production: Postgres; local có thể để trống để dùng SQLite) ---
# POSTGRES_URL=
# DATABASE_URL=
# STORAGE_URL=

# --- Resend (email waitlist, sequence, xác nhận đơn) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Cron /api/cron/email-sequence (tuỳ chọn; Vercel tự gửi Bearer khi có biến này) ---
# CRON_SECRET=

# --- SePay ---
# SEPAY_MERCHANT_ID=
# SEPAY_SECRET_KEY=
# SEPAY_WEBHOOK_API_KEY=
# SEPAY_PRODUCT_ID=
# NEXT_PUBLIC_SITE_URL=https://pickleball30phut.com

# --- Lead form → Make (tuỳ chọn) ---
# NEXT_PUBLIC_MAKE_WEBHOOK_URL=
